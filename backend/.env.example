# Database (Supabase connection pooler — port 6543 for PgBouncer transaction mode)
DATABASE_URL=postgresql+asyncpg://<user>.<project-ref>:<password>@aws-1-us-west-2.pooler.supabase.com:6543/postgres

# LLM API (OpenRouter)
LLM_API_KEY=sk-or-v1-...
LLM_BASE_URL=https://openrouter.ai/api/v1
INTERVIEW_MODEL=openai/gpt-4.1-mini
SYNTHESIS_MODEL=openai/gpt-4.1
PLANNING_MODEL=openai/gpt-4.1

# Embeddings (direct OpenAI — text-embedding-3-small at 1024 dims)
OPENAI_API_KEY=sk-proj-...

# Benchmark authentication key — passed as: Authorization: Bearer <value>
BENCHMARK_API_KEY=thoth-secret-2026
